@model QuanLyCauLacBo.Models.ViewModels.ClubListViewModel
@{
    ViewData["Title"] = "Câu lạc bộ";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="fas fa-users me-2 text-primary"></i>Câu lạc bộ</h2>
    @if (User.IsInRole("Admin") || User.IsInRole("ClubManager"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Tạo câu lạc bộ
        </a>
    }
</div>

<!-- Filter -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-7">
                <label class="form-label small fw-semibold text-muted">TÌM KIẾM</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-search"></i></span>
                    <input name="search" value="@Model.SearchTerm" class="form-control" placeholder="Tên câu lạc bộ, mô tả..." />
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold text-muted">TRẠNG THÁI</label>
                <select name="status" class="form-select">
                    <option value="">Tất cả</option>
                    <option value="Active" selected="@(Model.StatusFilter == "Active" ? "selected" : null)">Đang hoạt động</option>
                    <option value="Inactive" selected="@(Model.StatusFilter == "Inactive" ? "selected" : null)">Tạm ngưng</option>
                    <option value="Suspended" selected="@(Model.StatusFilter == "Suspended" ? "selected" : null)">Đã đình chỉ</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-filter me-1"></i>Lọc
                </button>
            </div>
        </form>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <p class="text-muted mb-0">Tìm thấy <strong>@Model.TotalClubs</strong> câu lạc bộ</p>
    @if (!string.IsNullOrEmpty(Model.SearchTerm) || !string.IsNullOrEmpty(Model.StatusFilter))
    {
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-times me-1"></i>Xóa bộ lọc
        </a>
    }
</div>

@if (Model.Clubs.Any())
{
    <div class="row g-4">
        @foreach (var club in Model.Clubs)
        {
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-start justify-content-between mb-3">
                            <div class="d-flex align-items-center">
                                <div class="rounded-circle me-3 d-flex align-items-center justify-content-center text-white fw-bold"
                                     style="width:52px;height:52px;min-width:52px;background:linear-gradient(135deg,#0d6efd,#6610f2);font-size:1.3rem;">
                                    @club.Name.Substring(0, 1)
                                </div>
                                <div>
                                    <h5 class="fw-bold mb-0">@club.Name</h5>
                                    <small class="text-muted">@club.Faculty</small>
                                </div>
                            </div>
                            <span class="badge @(club.Status == "Active" ? "bg-success" : club.Status == "Inactive" ? "bg-secondary" : "bg-danger")">
                                @(club.Status == "Active" ? "Hoạt động" : club.Status == "Inactive" ? "Tạm ngưng" : "Đình chỉ")
                            </span>
                        </div>
                        <p class="text-muted small mb-3" style="overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;">
                            @club.Description
                        </p>
                        <div class="row text-center border-top pt-3">
                            <div class="col-4">
                                <div class="fw-bold">@club.Members.Count(m => m.Status == "Active")</div>
                                <small class="text-muted">Thành viên</small>
                            </div>
                            <div class="col-4">
                                <div class="fw-bold">@club.Events.Count</div>
                                <small class="text-muted">Sự kiện</small>
                            </div>
                            <div class="col-4">
                                <div class="fw-bold">@club.FoundedDate.Year</div>
                                <small class="text-muted">Thành lập</small>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-white border-0 pb-4 px-4 pt-0">
                        <a asp-action="Details" asp-route-id="@club.Id" class="btn btn-primary w-100">
                            <i class="fas fa-eye me-2"></i>Xem chi tiết
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="fas fa-search fa-4x text-muted mb-3 opacity-50"></i>
        <h4 class="text-muted">Không tìm thấy câu lạc bộ nào</h4>
        <p class="text-muted">Thử thay đổi từ khóa tìm kiếm hoặc bộ lọc.</p>
        <a asp-action="Index" class="btn btn-primary">Xem tất cả CLB</a>
    </div>
}
