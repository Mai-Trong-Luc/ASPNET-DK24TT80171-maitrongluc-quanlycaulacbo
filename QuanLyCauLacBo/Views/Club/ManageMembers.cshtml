@model QuanLyCauLacBo.Models.ViewModels.MemberManagementViewModel
@{
    ViewData["Title"] = "Quản lý thành viên - " + Model.Club.Name;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-1"><i class="fas fa-users-cog me-2 text-warning"></i>Quản lý thành viên</h3>
        <p class="text-muted mb-0">@Model.Club.Name</p>
    </div>
    <a asp-action="Details" asp-route-id="@Model.Club.Id" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-2"></i>Quay lại
    </a>
</div>

<!-- Chờ duyệt -->
@if (Model.PendingMembers.Any())
{
    <div class="card border-0 shadow-sm mb-4 border-start border-warning border-4">
        <div class="card-header bg-warning bg-opacity-10 border-0 py-3">
            <h5 class="fw-bold mb-0 text-warning">
                <i class="fas fa-clock me-2"></i>Chờ duyệt (@Model.PendingMembers.Count)
            </h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Sinh viên</th>
                            <th>MSSV</th>
                            <th>Email</th>
                            <th>Ngày đăng ký</th>
                            <th class="text-end">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in Model.PendingMembers)
                        {
                            <tr>
                                <td class="fw-semibold">@m.User.FullName</td>
                                <td><code>@m.User.StudentId</code></td>
                                <td class="text-muted small">@m.User.Email</td>
                                <td class="text-muted small">@m.JoinedDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-end">
                                    <form asp-action="ApproveMember" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="clubMemberId" value="@m.Id" />
                                        <input type="hidden" name="clubId" value="@Model.Club.Id" />
                                        <button type="submit" class="btn btn-success btn-sm me-1">
                                            <i class="fas fa-check me-1"></i>Duyệt
                                        </button>
                                    </form>
                                    <form asp-action="RejectMember" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="clubMemberId" value="@m.Id" />
                                        <input type="hidden" name="clubId" value="@Model.Club.Id" />
                                        <button type="submit" class="btn btn-danger btn-sm">
                                            <i class="fas fa-times me-1"></i>Từ chối
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<!-- Thành viên đang hoạt động -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 py-3">
        <h5 class="fw-bold mb-0"><i class="fas fa-users me-2 text-success"></i>Thành viên đang hoạt động (@Model.ActiveMembers.Count)</h5>
    </div>
    <div class="card-body p-0">
        @if (Model.ActiveMembers.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Họ và tên</th>
                            <th>MSSV</th>
                            <th>Email</th>
                            <th>Vai trò</th>
                            <th>Ngày tham gia</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in Model.ActiveMembers)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold"
                                             style="width:32px;height:32px;font-size:0.75rem;min-width:32px;">
                                            @m.User.FullName.Substring(0, 1)
                                        </div>
                                        <span class="fw-semibold">@m.User.FullName</span>
                                    </div>
                                </td>
                                <td><code>@m.User.StudentId</code></td>
                                <td class="text-muted small">@m.User.Email</td>
                                <td>
                                    <span class="badge @(m.Role == "President" ? "bg-danger" : m.Role == "Vice President" ? "bg-warning text-dark" : "bg-secondary")">
                                        @m.Role
                                    </span>
                                </td>
                                <td class="text-muted small">@m.JoinedDate.ToString("dd/MM/yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted text-center py-4">Chưa có thành viên đang hoạt động.</p>
        }
    </div>
</div>
