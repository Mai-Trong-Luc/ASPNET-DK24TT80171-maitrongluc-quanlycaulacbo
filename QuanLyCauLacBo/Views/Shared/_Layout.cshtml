<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CLB Sinh Viên KTCN</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                <i class="fas fa-university me-2"></i>CLB Sinh Viên KTCN
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Club" asp-action="Index">
                            <i class="fas fa-users me-1"></i>Câu lạc bộ
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Event" asp-action="Index">
                            <i class="fas fa-calendar-alt me-1"></i>Sự kiện
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Activity" asp-action="Index">
                            <i class="fas fa-tasks me-1"></i>Hoạt động
                        </a>
                    </li>
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="fas fa-cog me-1"></i>Quản trị
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Dashboard"><i class="fas fa-tachometer-alt me-2"></i>Dashboard</a></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Users"><i class="fas fa-user-cog me-2"></i>Quản lý người dùng</a></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Notifications"><i class="fas fa-bell me-2"></i>Quản lý thông báo</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-controller="Club" asp-action="Create"><i class="fas fa-plus me-2"></i>Tạo CLB mới</a></li>
                            </ul>
                        </li>
                    }
                    @if (User.IsInRole("ClubManager"))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="fas fa-tools me-1"></i>Quản lý
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Event" asp-action="Create"><i class="fas fa-plus me-2"></i>Tạo sự kiện</a></li>
                                <li><a class="dropdown-item" asp-controller="Activity" asp-action="Create"><i class="fas fa-plus me-2"></i>Tạo hoạt động</a></li>
                                <li><a class="dropdown-item" asp-controller="Notification" asp-action="Create"><i class="fas fa-plus me-2"></i>Gửi thông báo</a></li>
                            </ul>
                        </li>
                    }
                </ul>
                <ul class="navbar-nav ms-auto align-items-center">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item me-2">
                            <a class="nav-link position-relative" asp-controller="Notification" asp-action="Index">
                                <i class="fas fa-bell"></i>
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" data-bs-toggle="dropdown">
                                <div class="rounded-circle bg-warning text-dark d-flex align-items-center justify-content-center fw-bold"
                                     style="width:32px;height:32px;font-size:0.85rem;">
                                    @(User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value?.Substring(0, 1).ToUpper())
                                </div>
                                <span class="d-none d-lg-inline">@User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile"><i class="fas fa-user me-2"></i>Hồ sơ cá nhân</a></li>
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword"><i class="fas fa-key me-2"></i>Đổi mật khẩu</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout">
                                        <i class="fas fa-sign-out-alt me-2"></i>Đăng xuất
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">
                                <i class="fas fa-sign-in-alt me-1"></i>Đăng nhập
                            </a>
                        </li>
                        <li class="nav-item ms-2">
                            <a class="btn btn-warning btn-sm fw-bold" asp-controller="Account" asp-action="Register">
                                <i class="fas fa-user-plus me-1"></i>Đăng ký
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main>
        <div class="container my-4">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                    <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </div>
    </main>

    <footer class="bg-dark text-white py-4 mt-5">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-3">
                    <h5 class="fw-bold"><i class="fas fa-university me-2"></i>CLB Sinh Viên KTCN</h5>
                    <p style="color: rgba(255, 255, 255, 0.7) !important;" class="small">Hệ thống quản lý câu lạc bộ và hoạt động sinh viên trường Kỹ thuật và Công nghệ.</p>
                </div>
                <div class="col-md-4 mb-3">
                    <h6 class="fw-bold">Liên kết nhanh</h6>
                    <ul class="list-unstyled small">
                        <li><a href="/Club" style="color: rgba(255, 255, 255, 0.7) !important;" class="text-decoration-none"><i class="fas fa-chevron-right me-1"></i>Câu lạc bộ</a></li>
                        <li><a href="/Event" style="color: rgba(255, 255, 255, 0.7) !important;" class="text-decoration-none"><i class="fas fa-chevron-right me-1"></i>Sự kiện</a></li>
                        <li><a href="/Activity" style="color: rgba(255, 255, 255, 0.7) !important;" class="text-decoration-none"><i class="fas fa-chevron-right me-1"></i>Hoạt động</a></li>
                    </ul>
                </div>
                <div class="col-md-4 mb-3">
                    <h6 class="fw-bold">Liên hệ</h6>
                    <p style="color: rgba(255, 255, 255, 0.7) !important;" class="small">
                        <i class="fas fa-envelope me-1"></i> ctsv@ktcn.edu.vn<br />
                        <i class="fas fa-phone me-1"></i> (0284) 123-4567<br />
                        <i class="fas fa-map-marker-alt me-1"></i> 123 Nguyễn Văn Linh, TP.HCM
                    </p>
                </div>
            </div>
            <hr class="border-secondary">
            <p style="color: rgba(255, 255, 255, 0.5) !important;" class="text-center small mb-0">
                &copy; @DateTime.Now.Year Trường Kỹ thuật và Công nghệ - Hệ thống Quản lý Câu lạc bộ Sinh viên
            </p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
