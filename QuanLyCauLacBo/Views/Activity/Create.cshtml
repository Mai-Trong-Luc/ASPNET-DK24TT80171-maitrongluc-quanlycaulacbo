@model QuanLyCauLacBo.Models.ViewModels.ActivityFormViewModel
@{
    ViewData["Title"] = "Tạo hoạt động";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-0 shadow">
            <div class="card-header bg-warning text-dark py-3 border-0">
                <h4 class="mb-0 fw-bold"><i class="fas fa-plus me-2"></i>Tạo hoạt động mới</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="ClubId" class="form-label fw-semibold"></label>
                            <select asp-for="ClubId" class="form-select">
                                <option value="">-- Chọn câu lạc bộ --</option>
                                @foreach (var club in Model.Clubs)
                                {
                                    <option value="@club.Id">@club.Name</option>
                                }
                            </select>
                            <span asp-validation-for="ClubId" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Title" class="form-label fw-semibold"></label>
                            <input asp-for="Title" class="form-control" placeholder="Tên hoạt động" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label fw-semibold"></label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Mô tả hoạt động..."></textarea>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="StartDate" class="form-label fw-semibold"></label>
                            <input asp-for="StartDate" class="form-control" type="date" />
                            <span asp-validation-for="StartDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EndDate" class="form-label fw-semibold"></label>
                            <input asp-for="EndDate" class="form-control" type="date" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Location" class="form-label fw-semibold"></label>
                            <input asp-for="Location" class="form-control" placeholder="Địa điểm" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Status" class="form-label fw-semibold"></label>
                            <select asp-for="Status" class="form-select">
                                <option value="Planning">Lên kế hoạch</option>
                                <option value="InProgress">Đang thực hiện</option>
                                <option value="Completed">Đã hoàn thành</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Progress" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <input asp-for="Progress" class="form-control" type="number" min="0" max="100" value="0" />
                                <span class="input-group-text">%</span>
                            </div>
                        </div>
                    </div>
                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-warning text-dark px-4 fw-bold">
                            <i class="fas fa-save me-2"></i>Tạo hoạt động
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
