@model QuanLyCauLacBo.Models.ViewModels.ActivityListViewModel
@{
    ViewData["Title"] = "Hoạt động";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="fas fa-tasks me-2 text-warning"></i>Hoạt động</h2>
    @if (User.IsInRole("Admin") || User.IsInRole("ClubManager"))
    {
        <a asp-action="Create" class="btn btn-warning text-dark fw-bold">
            <i class="fas fa-plus me-2"></i>Tạo hoạt động
        </a>
    }
</div>

<!-- Filter -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <input name="search" value="@Model.SearchTerm" class="form-control" placeholder="Tìm kiếm hoạt động..." />
            </div>
            <div class="col-md-3">
                <select name="clubId" class="form-select">
                    <option value="">Tất cả CLB</option>
                    @foreach (var club in Model.Clubs)
                    {
                        <option value="@club.Id" selected="@(Model.ClubIdFilter == club.Id ? "selected" : null)">@club.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <select name="status" class="form-select">
                    <option value="">Tất cả trạng thái</option>
                    <option value="Planning" selected="@(Model.StatusFilter == "Planning" ? "selected" : null)">Lên kế hoạch</option>
                    <option value="InProgress" selected="@(Model.StatusFilter == "InProgress" ? "selected" : null)">Đang thực hiện</option>
                    <option value="Completed" selected="@(Model.StatusFilter == "Completed" ? "selected" : null)">Đã hoàn thành</option>
                    <option value="Cancelled" selected="@(Model.StatusFilter == "Cancelled" ? "selected" : null)">Đã hủy</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-warning w-100 fw-bold text-dark">Lọc</button>
            </div>
        </form>
    </div>
</div>

@if (Model.Activities.Any())
{
    <div class="row g-4">
        @foreach (var act in Model.Activities)
        {
            var pct = act.Progress ?? 0;
            var barColor = pct >= 100 ? "success" : pct >= 60 ? "primary" : pct >= 30 ? "warning" : "danger";
            var statusBadge = act.Status switch
            {
                "Completed" => "success",
                "InProgress" => "primary",
                "Planning" => "warning text-dark",
                _ => "secondary"
            };
            var statusLabel = act.Status switch
            {
                "Completed" => "Hoàn thành",
                "InProgress" => "Đang thực hiện",
                "Planning" => "Lên kế hoạch",
                _ => "Đã hủy"
            };

            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge bg-@statusBadge">@statusLabel</span>
                            <small class="text-muted">@act.Club?.Name</small>
                        </div>
                        <h5 class="fw-bold mb-2">@act.Title</h5>
                        <p class="text-muted small mb-3" style="overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;">
                            @act.Description
                        </p>
                        <div class="mb-2">
                            <div class="d-flex justify-content-between mb-1">
                                <small class="text-muted">Tiến độ</small>
                                <small class="fw-semibold">@pct%</small>
                            </div>
                            <div class="progress" style="height:8px;">
                                <div class="progress-bar bg-@barColor rounded-pill" style="width:@pct%"></div>
                            </div>
                        </div>
                        <div class="text-muted small mt-2">
                            <i class="fas fa-calendar me-1"></i>@act.StartDate.ToString("dd/MM/yyyy")
                            @if (act.EndDate.HasValue)
                            {
                                <span> — @act.EndDate.Value.ToString("dd/MM/yyyy")</span>
                            }
                        </div>
                    </div>
                    <div class="card-footer bg-white border-0 pb-4 px-4 pt-0">
                        <a asp-action="Details" asp-route-id="@act.Id" class="btn btn-warning text-dark w-100 fw-bold">
                            <i class="fas fa-eye me-2"></i>Xem chi tiết
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="fas fa-tasks fa-4x text-muted mb-3 opacity-50"></i>
        <h4 class="text-muted">Không có hoạt động nào</h4>
    </div>
}
