@model List<QuanLyCauLacBo.Models.Domain.User>
@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="fas fa-users-cog me-2 text-primary"></i>Quản lý người dùng</h2>
    <span class="badge bg-primary fs-6">@Model.Count người dùng</span>
</div>

<!-- Filter -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-5">
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-search"></i></span>
                    <input name="search" value="@ViewBag.SearchTerm" class="form-control" placeholder="Tên, tên đăng nhập, MSSV..." />
                </div>
            </div>
            <div class="col-md-4">
                <select name="role" class="form-select">
                    <option value="">Tất cả vai trò</option>
                    <option value="Admin" selected="@(ViewBag.RoleFilter == "Admin" ? "selected" : null)">Admin</option>
                    <option value="ClubManager" selected="@(ViewBag.RoleFilter == "ClubManager" ? "selected" : null)">Quản lý CLB</option>
                    <option value="Student" selected="@(ViewBag.RoleFilter == "Student" ? "selected" : null)">Sinh viên</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100">Tìm kiếm</button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-primary">
                <tr>
                    <th>Người dùng</th>
                    <th>MSSV</th>
                    <th>Email</th>
                    <th>Vai trò</th>
                    <th>Trạng thái</th>
                    <th>Ngày tạo</th>
                    <th class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="rounded-circle text-white d-flex align-items-center justify-content-center fw-bold flex-shrink-0"
                                     style="width:34px;height:34px;background:@(user.Role == "Admin" ? "#dc3545" : user.Role == "ClubManager" ? "#ffc107" : "#0d6efd");font-size:0.8rem;color:@(user.Role == "ClubManager" ? "#000" : "#fff") !important;">
                                    @user.FullName.Substring(0, 1)
                                </div>
                                <div>
                                    <div class="fw-semibold small">@user.FullName</div>
                                    <div class="text-muted" style="font-size:0.75rem;">@@@user.Username</div>
                                </div>
                            </div>
                        </td>
                        <td><code class="small">@(user.StudentId ?? "—")</code></td>
                        <td class="text-muted small">@user.Email</td>
                        <td>
                            <form asp-action="ChangeUserRole" method="post" class="d-flex align-items-center gap-1">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="userId" value="@user.Id" />
                                <select name="role" class="form-select form-select-sm" style="width:130px;" onchange="this.form.submit()">
                                    <option value="Student" selected="@(user.Role == "Student" ? "selected" : null)">Sinh viên</option>
                                    <option value="ClubManager" selected="@(user.Role == "ClubManager" ? "selected" : null)">Quản lý CLB</option>
                                    <option value="Admin" selected="@(user.Role == "Admin" ? "selected" : null)">Admin</option>
                                </select>
                            </form>
                        </td>
                        <td>
                            <span class="badge @(user.IsActive ? "bg-success" : "bg-danger")">
                                @(user.IsActive ? "Hoạt động" : "Bị khóa")
                            </span>
                        </td>
                        <td class="text-muted small">@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td class="text-end">
                            <form asp-action="ToggleUserStatus" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="userId" value="@user.Id" />
                                <button type="submit" class="btn @(user.IsActive ? "btn-outline-danger" : "btn-outline-success") btn-sm"
                                        onclick="return confirm('@(user.IsActive ? "Khóa" : "Kích hoạt") tài khoản này?')">
                                    <i class="fas @(user.IsActive ? "fa-lock" : "fa-unlock") me-1"></i>
                                    @(user.IsActive ? "Khóa" : "Mở khóa")
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
